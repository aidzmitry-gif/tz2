# URL и ключи проекта Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Необязательно: service-role ключ для server-side запросов в обход RLS.
# Если не задан, приложение использует anon-ключ (его достаточно — есть SELECT-политики).
# ВНИМАНИЕ: service-role ключ секретный, не коммитьте его и не используйте на клиенте.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
